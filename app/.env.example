# Proveedor por defecto: groq | openai | gemini
LLM_PROVIDER=groq

# Si es true, ante fallo del proveedor principal se prueban los demás que tengan API key (orden: groq → openai → gemini).
LLM_FALLBACK_ENABLED=true

# --- Groq ---
# https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Gemini (SDK: google-genai) ---
# API key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Alternativa reconocida por el código:
# GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
